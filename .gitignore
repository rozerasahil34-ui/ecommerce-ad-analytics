# =============================================================================
# E-commerce Ad Campaign Analytics - Gitignore
# =============================================================================

# Ignore large raw Olist datasets (available on Kaggle)
data/raw/olist_customers_dataset.csv
data/raw/olist_geolocation_dataset.csv
data/raw/olist_order_items_dataset.csv
data/raw/olist_order_payments_dataset.csv
data/raw/olist_order_reviews_dataset.csv
data/raw/olist_orders_dataset.csv
data/raw/olist_products_dataset.csv
data/raw/olist_sellers_dataset.csv
data/raw/product_category_name_translation.csv

# Ignore large processed tables and intermediate datasets
data/processed/customers_clean.csv
data/processed/items_clean.csv
data/processed/orders_clean.csv
data/processed/payments_clean.csv
data/processed/products_clean.csv
data/processed/reviews_clean.csv
data/processed/master_orders.csv
data/processed/simulated_ad_spend.csv
data/processed/ad_campaigns.csv

# Do NOT ignore A/B test summary files, charts, or images
# These are small and critical for repository visualization
!data/processed/*.png
!data/processed/ab_test_results.csv
!data/processed/ab_test_segments.csv

# Ignore Python & Jupyter Checkpoints
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/
*/.ipynb_checkpoints/
.ipynb_checkpoints

# Ignore operating system files
.DS_Store
Thumbs.db
desktop.ini
*.xlsx.tmp
~$*.docx
~$*.xlsx
